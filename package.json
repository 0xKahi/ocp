{
  "name": "opencode-profiles",
  "version": "1.4.1",
  "description": "OCP CLI - manage and switch between local global opencode profiles",
  "author": "0xKahi",
  "license": "MIT",
  "module": "index.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.12"
  },
  "keywords": [
    "opencode",
    "cli",
    "extensions",
    "profiles"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/0xKahi/ocp.git"
  },
  "bin": {
    "ocp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run dist/index.js",
    "prod": "bun run start",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "buildSchema": "bun run scripts/build-schema.ts",
    "prepublishOnly": "bun run build",
    "release": "changeset publish",
    "version": "changeset version",
    "changeset": "changeset",
    "biome": "biome check ./src",
    "lint": "bun biome",
    "lint:fix": "bun biome --write",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "kleur": "^4.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "latest",
    "@types/node": "^24.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
