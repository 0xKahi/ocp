{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/0xKahi/ocp/main/assets/ocp.schema.json",
  "title": "Opencode Profiles Configuration",
  "description": "Configuration schema for ocp (opencode-profiles) plugin",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "startup": {
      "type": "object",
      "properties": {
        "randomPort": {
          "default": false,
          "description": "assign a random port to the server on profile startup",
          "type": "boolean"
        }
      },
      "required": [
        "randomPort"
      ],
      "additionalProperties": false
    },
    "profiles": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "startup",
    "profiles"
  ],
  "additionalProperties": false
}